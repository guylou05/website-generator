COMPOSE_PROJECT_NAME=website-generator
POSTGRES_DB=website_generator
POSTGRES_USER=website_generator
POSTGRES_PASSWORD=local-development-only
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8080
DASHBOARD_PORT=3000
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# AI provider (mock is the safe local/test default)
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=2
INTERNAL_WORKER_TOKEN=replace-with-at-least-32-random-characters
API_INTERNAL_BASE_URL=http://nginx/api/internal
WORKER_CONCURRENCY=2
JOB_HEARTBEAT_INTERVAL_MS=15000
JOB_STALE_AFTER_SECONDS=120

# Organization billing (server-only except publishable key)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=
STRIPE_PORTAL_CONFIGURATION_ID=
STRIPE_ENABLE_PROMOTION_CODES=false
STRIPE_ENABLE_AUTOMATIC_TAX=false
BILLING_GRACE_PERIOD_DAYS=7
BILLING_USAGE_TIMEZONE=UTC
BILLING_ENFORCEMENT_ENABLED=true
