APP_NAME="Website Generator API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
LOG_CHANNEL=stack
LOG_LEVEL=debug
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=website_generator
DB_USERNAME=website_generator
DB_PASSWORD=local-development-only
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000
DASHBOARD_URL=http://localhost:3000
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=hello@sitefoundry.test

# Provider credentials remain server-only and are never persisted or returned.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=2

# Outbound WordPress REST request timeout in seconds.
WORDPRESS_REQUEST_TIMEOUT=15

# Shared only with trusted workers. Rotate by updating API and workers together, then restarting them.
INTERNAL_WORKER_TOKEN=replace-with-at-least-32-random-characters
JOB_STALE_AFTER_SECONDS=120

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_AGENCY_YEARLY=
STRIPE_PORTAL_CONFIGURATION_ID=
STRIPE_ENABLE_PROMOTION_CODES=false
STRIPE_ENABLE_AUTOMATIC_TAX=false
BILLING_GRACE_PERIOD_DAYS=7
BILLING_USAGE_TIMEZONE=UTC
BILLING_ENFORCEMENT_ENABLED=true
MEDIA_DISK=media
MEDIA_S3_ENDPOINT=
MEDIA_S3_REGION=us-east-1
MEDIA_S3_BUCKET=website-generator-media
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_S3_PATH_STYLE=true
MEDIA_PUBLIC_BASE_URL=
MEDIA_MAX_UPLOAD_MB=5
MEDIA_SIGNED_URL_TTL_SECONDS=900
MEDIA_ORIGINAL_RETENTION_DAYS=30
MEDIA_DERIVATIVE_FORMATS=webp,jpeg
MEDIA_AVIF_ENABLED=false
MEDIA_WEBP_ENABLED=true
MEDIA_IMAGE_PROVIDER=mock
MEDIA_STOCK_PROVIDER=mock
MEDIA_PROCESSING_CONCURRENCY=2
