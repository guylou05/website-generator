# Browser-visible base URL for the Laravel JSON API. Never put provider secrets here.
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Server-only compatibility settings for the Next.js generation route.
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=60000
OPENAI_MAX_RETRIES=2
