{
  "name": "@website-generator/renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./elementor": {
      "types": "./dist/elementor/index.d.ts",
      "default": "./dist/elementor/index.js"
    },
    "./preview": {
      "types": "./dist/preview/index.d.ts",
      "default": "./dist/preview/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc --build --pretty false",
    "test": "pnpm run build && node --test src/elementor/tests/*.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@website-generator/design-system": "workspace:*",
    "@website-generator/shared": "workspace:*"
  }
}
