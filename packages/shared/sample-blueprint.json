        {
          "id": "contact-form",
          "type": "contact",
          "layout": {
            "container": "narrow",
            "columns": 1,
            "spacing": "large",
            "background": "surface"
          },
          "components": [
            {
              "id": "contact-title",
              "type": "heading",
              "level": 1,
              "text": "Let's solve what is next"
            },
            {
              "id": "inquiry-form",
              "type": "form",
              "name": "consultation-request",
              "action": "/api/contact",
              "method": "POST",
              "fields": [
                {
                  "id": "field-name",
                  "name": "name",
                  "label": "Name",
                  "type": "text",
                  "required": true,
                  "placeholder": "Your name"
                },
                {
                  "id": "field-email",
                  "name": "email",
                  "label": "Work email",
                  "type": "email",
                  "required": true,
                  "placeholder": "you@company.com"
                },
                {
                  "id": "field-interest",
                  "name": "interest",
                  "label": "How can we help?",
                  "type": "select",
                  "required": true,
                  "options": [
                    { "label": "Managed IT", "value": "managed-it" },
                    { "label": "Cybersecurity", "value": "cybersecurity" },
                    { "label": "Cloud services", "value": "cloud" }
                  ]
                },
                {
                  "id": "field-message",
                  "name": "message",
                  "label": "Message",
                  "type": "textarea",
                  "required": true
                }
              ],
              "submitLabel": "Request consultation",
              "successMessage": "Thanks. A Northstar specialist will contact you shortly.",
              "consentText": "By submitting, you agree that Northstar may contact you about this request."
            }
          ]
        }
      ]
